# Database (Supabase / Postgres)
DATABASE_URL=postgresql+asyncpg://<db_user>:<db_pass>@<db_host>:5432/<db_name>

# SentinelHub (for real NDVI). Get from your SentinelHub dashboard.
SENTINELHUB_CLIENT_ID=your_client_id
SENTINELHUB_CLIENT_SECRET=your_client_secret
# Optionally for WMS instance (for frontend)
SENTINELHUB_INSTANCE_ID=your_instance_id

# OpenWeatherMap
OPENWEATHER_API_KEY=your_openweather_key

# JWT secret for auth
JWT_SECRET=supersecretjwtkey

# App config
APP_HOST=0.0.0.0
APP_PORT=8000
